// geo-constanza-api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 1. USUARIOS (Guardias, Supervisores, Central, Admins) ───
// Roles: 'pauta' | 'libre' | 'supervisor' | 'central' | 'admin'
model Usuario {
  id                       String     @id @default(uuid())
  rut                      String     @unique
  nombre                   String
  email                    String     @unique
  telefono                 String?
  password_hash            String
  rol                      String     // 'pauta', 'libre', 'supervisor', 'central', 'admin'
  estado                   String     @default("activo") // 'activo', 'inactivo'
  two_factor_secret        String?

  // Para GGSS: diferencia en_pauta (pauta fija 4x4) vs libre (eventual)
  tipo_ggss                String?    // 'pauta' | 'libre' — solo aplica a rol 'pauta' o 'libre'

  // Para GGSS libre: instalación base donde puede trabajar
  instalacion_asignada_id  String?

  // Para Supervisores: comunas bajo su responsabilidad (ej. ["Puente Alto", "La Florida"])
  comunas_cobertura        Json?

  // Dispositivo registrado para validación de acceso
  dispositivo_principal    String?    // 'tablet_empresa' | 'mobil_empresa' | 'mobil_personal'
  imei_dispositivo         String?    // IMEI de la tablet/móvil registrada

  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt

  // Relaciones
  turnos                   Turno[]
  asistencias              Asistencia[]
  novedades                Novedad[]
  auditorias               Auditoria[]
  instalaciones_sup        Supervisor_Instalacion[]
  solicitudes              Solicitud[] @relation("UsuarioSolicita")
  solicitudes_rev          Solicitud[] @relation("SupervisorRevisa")
  instalacion_asignada     Instalacion? @relation("ggss_asignado", fields: [instalacion_asignada_id], references: [id])
}

// ─── 2. INSTALACIONES (Recintos a proteger) ───
model Instalacion {
  id                  String     @id @default(uuid())
  nombre              String
  direccion           String?
  latitud             Float
  longitud            Float
  radio_geofence_m    Int        @default(100) // Metros de tolerancia para GPS
  tipo_recinto        String?
  nivel_criticidad    String     @default("Media") // Alta, Media, Baja
  comuna              String?    // Comuna donde se ubica la instalación (para cobertura de supervisor)
  estado              String     @default("activo")
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  // Relaciones
  turnos              Turno[]
  asistencias         Asistencia[]
  novedades           Novedad[]
  supervisores        Supervisor_Instalacion[]
  ggss_asignados      Usuario[]    @relation("ggss_asignado")
}

// ─── 3. TABLA INTERMEDIA: SUPERVISOR - INSTALACIÓN ───
model Supervisor_Instalacion {
  id               String      @id @default(uuid())
  supervisor_id    String
  instalacion_id   String
  
  supervisor       Usuario     @relation(fields: [supervisor_id], references: [id])
  instalacion      Instalacion @relation(fields: [instalacion_id], references: [id])

  @@unique([supervisor_id, instalacion_id])
}

// ─── 4. TURNOS (Planificación) ───
model Turno {
  id                  String       @id @default(uuid())
  usuario_id          String
  instalacion_id      String
  fecha               DateTime     @db.Date
  hora_inicio         String       // Ej: "06:00"
  hora_fin            String       // Ej: "14:00"
  tipo_turno          String       @default("normal") // normal, extra
  estado              String       @default("programado") // programado, completado, cancelado
  motivo_cancelacion  String?
  creado_por          String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  usuario             Usuario      @relation(fields: [usuario_id], references: [id])
  instalacion         Instalacion  @relation(fields: [instalacion_id], references: [id])
  asistencias         Asistencia[]
  novedades           Novedad[]
}

// ─── 5. ASISTENCIA (Marcajes reales) ───
model Asistencia {
  id                  String       @id @default(uuid())
  usuario_id          String
  turno_id            String
  instalacion_id      String
  hora_entrada        DateTime
  hora_salida         DateTime?
  metodo_entrada      String       // 'totem', 'fallback_telefono'
  metodo_salida       String?
  estado              String       // 'normal', 'tardio'
  minutos_retraso     Int          @default(0)
  latitud_entrada     Float?
  longitud_entrada    Float?
  es_fallback         Boolean      @default(false)
  horas_trabajadas    Float?
  horas_extra         Float?
  created_at          DateTime     @default(now())

  dispositivo_usado   String?      // 'tablet' | 'mobil_empresa' | 'mobil_personal'

  usuario             Usuario      @relation(fields: [usuario_id], references: [id])
  turno               Turno        @relation(fields: [turno_id], references: [id])
  instalacion         Instalacion  @relation(fields: [instalacion_id], references: [id])
}

// ─── 6. NOVEDADES (Incidentes) ───
model Novedad {
  id                  String       @id @default(uuid())
  usuario_id          String
  instalacion_id      String
  turno_id            String
  tipo                String
  descripcion         String
  urgencia            String       // verde, amarillo, rojo
  foto_url            String?
  latitud             Float?
  longitud            Float?
  estado              String       @default("abierta") // abierta, escalada, resuelta
  gps_dentro_rango    Boolean?     @default(true)      // false = guardia fuera del radio al reportar
  comentario_cierre   String?
  atendida_por        String?
  fecha_atencion      DateTime?
  created_at          DateTime     @default(now())

  usuario             Usuario      @relation(fields: [usuario_id], references: [id])
  instalacion         Instalacion  @relation(fields: [instalacion_id], references: [id])
  turno               Turno        @relation(fields: [turno_id], references: [id])
}

// ─── 7. SOLICITUDES (Vacaciones, Permisos, Traslados, Turnos) ───
// tipos: 'vacaciones' | 'dias_libres' | 'turno_extra' | 'traslado' | 'turno'
model Solicitud {
  id                  String       @id @default(uuid())
  usuario_id          String
  tipo                String       // 'vacaciones', 'dias_libres', 'turno_extra', 'traslado', 'turno'
  fecha_desde         DateTime     @db.Date
  fecha_hasta         DateTime?    @db.Date
  motivo              String?
  estado              String       @default("pendiente") // 'pendiente', 'aprobada', 'rechazada'
  revisada_por        String?
  comentario_revision String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  usuario             Usuario      @relation("UsuarioSolicita", fields: [usuario_id], references: [id])
  revisor             Usuario?     @relation("SupervisorRevisa", fields: [revisada_por], references: [id])
}

// ─── 8. AUDITORÍA (Seguridad Inmutable) ───
model Auditoria {
  id                  String       @id @default(uuid())
  usuario_id          String
  accion              String       // 'LOGIN', 'CREAR_TURNO', 'APROBAR_SOL'
  tabla_afectada      String
  registro_id         String
  valores_antes       Json?
  valores_despues     Json?
  ip_address          String?
  user_agent          String?
  created_at          DateTime     @default(now())

  usuario             Usuario      @relation(fields: [usuario_id], references: [id])
}